generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["booking", "content"]
}

enum Status {
  Active
  Inactive

  @@schema("content")
}

model HeroBanner {
  id        Int      @id @default(autoincrement())
  headline  String
  title     String
  remarks   String
  image     String   @db.Text
  status    Status @default(Active)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("herobanner")
  @@schema("content")
}

model Carousel {
  id        Int      @id @default(autoincrement())
  headline  String
  message   String
  title     String
  remarks   String
  status    Status   @default(Active)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  carouselImage    CarouselImage[]
  @@map("carousel")
  @@schema("content")
}

model CarouselImage {
  id          Int      @id @default(autoincrement())
  carouselId  Int
  image       String
  caption     String?
  order       Int
  status      Status   @default(Active)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  carousel    Carousel @relation(fields: [carouselId], references: [id], onDelete: Cascade)

  @@index([carouselId])
  @@map("carouselimage")
  @@schema("content")
}

model Room {
  id        Int      @id @default(autoincrement())
  name      String
  capacity  Int
  status    String   @default("Active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("room")
  @@schema("booking")
}
