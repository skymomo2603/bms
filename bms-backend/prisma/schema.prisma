generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["booking", "content"]
}

enum HeroBannerStatus {
  Active
  Inactive

  @@schema("content")
}

model HeroBanner {
  id        Int      @id @default(autoincrement())
  title     String
  remarks   String
  image     String   @db.Text
  status    HeroBannerStatus @default(Active)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("herobanner")
  @@schema("content")
}

model Room {
  id        Int      @id @default(autoincrement())
  name      String
  capacity  Int
  status    String   @default("Active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("room")
  @@schema("booking")
}
